{
  "functions": {
    "server.js": {
      "runtime": "nodejs18.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/login",
      "dest": "/login.html"
    },
    {
      "src": "/game",
      "dest": "/game.html"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}