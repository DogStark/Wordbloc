  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "@openzeppelin/contracts": "^4.9.6",
    "dotenv": "^16.6.1",
    "hardhat": "^2.28.6"
  },
  "dependencies": {
    "@celo/contractkit": "^5.2.1"
  },
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/llinsss/Wordbloc.git"
  },
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/llinsss/Wordbloc/issues"
