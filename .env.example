# SpellBloc Celo Deployment Configuration
# Copy this file to .env and fill in your values

# Deployment Configuration
PRIVATE_KEY=your_private_key_here
CELOSCAN_API_KEY=your_celoscan_api_key_here

# Celo Network URLs (default values, usually don't need to change)
CELO_RPC_URL=https://forno.celo.org
ALFAJORES_RPC_URL=https://alfajores-forno.celo-testnet.org

# Contract Addresses (will be filled after deployment)
NEXT_PUBLIC_PAYMENT_CONTRACT=
PAYMENT_CONTRACT_ADDRESS=
NEXT_PUBLIC_ACHIEVEMENTS_CONTRACT=
NEXT_PUBLIC_LEADERBOARD_CONTRACT=

# Celo Token Addresses (mainnet)
CUSD_TOKEN_ADDRESS=0x765DE816845861e75A25fCA122bb6898B8B1282a
CELO_TOKEN_ADDRESS=0x471EcE3750Da237f93B8E339c536989b8978a438

# MiniPay Configuration
NEXT_PUBLIC_MINIPAY_ENABLED=true
NEXT_PUBLIC_CELO_NETWORK=alfajores
NEXT_PUBLIC_CELO_CHAIN_ID=44787

# Development Settings
REPORT_GAS=true
HARDHAT_NETWORK=celo

# Proof of Ship Submission
SUBMISSION_TITLE="SpellBloc: AI-Powered Spelling Education with Blockchain Verification"
SUBMISSION_DESCRIPTION="Revolutionary education platform combining AI tutoring with MiniPay payments"
DEMO_URL=https://spellbloc-demo.vercel.app
GITHUB_URL=https://github.com/your-username/spellbloc
